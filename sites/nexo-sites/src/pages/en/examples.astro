---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import ExamplesGrid from '../../components/ExamplesGrid.astro';
import { t } from '../../i18n';

const locale = 'en' as const;
const tr = t(locale);
---
<BaseLayout locale={locale} title={tr.meta.examplesTitle} description={tr.meta.examplesDesc} canonicalPath="/en/examples/" >
  <Header locale={locale} active="examples" />

  <main class="mx-auto max-w-6xl px-4 py-14">
    <h1 class="text-4xl font-extrabold">{tr.examples.title}</h1>
    <p class="mt-3 max-w-2xl text-[color:var(--muted)]">{tr.examples.subtitle}</p>

    <div class="mt-8">
      <ExamplesGrid locale={locale} />
    </div>

    <div class="mt-12 rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-8 prose-em">
      <h2 class="text-2xl font-extrabold" set:html={tr.examples.ctaTitle} />
      <p class="mt-2 text-[color:var(--muted)]">{tr.examples.ctaSubtitle}</p>
    </div>
  </main>

  <CTA
    locale={locale}
    title={'Want an example for your <em>industry</em>?'}
    subtitle={'Message me on WhatsApp and I’ll share relevant references.'}
  />
  <Footer locale={locale} />
</BaseLayout>
