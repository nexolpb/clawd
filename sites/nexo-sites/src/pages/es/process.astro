---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import { t } from '../../i18n';

const locale = 'es' as const;
const tr = t(locale);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: tr.faq.items.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a }
  }))
};
---

<BaseLayout locale={locale} title={tr.meta.processTitle} description={tr.meta.processDesc} canonicalPath="/es/process/" schema={schema} >
  <Header locale={locale} active="process" />

  <main class="mx-auto max-w-6xl px-4 py-14">
    <h1 class="text-4xl font-extrabold">{tr.process.title}</h1>
    <p class="mt-3 max-w-2xl text-[color:var(--muted)]">{tr.process.subtitle}</p>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {tr.process.steps.map((s, idx) => (
        <div class="rounded-xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
          <div class="tabular text-xs font-semibold text-[color:var(--accent)]">Paso 0{idx+1}</div>
          <div class="mt-2 text-lg font-bold">{s.title}</div>
          <p class="mt-2 text-sm text-[color:var(--muted)]">{s.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-14">
      <h2 class="text-2xl font-extrabold">{tr.faq.title}</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {tr.faq.items.map((it) => (
          <details class="rounded-xl border border-[color:var(--border)] bg-[color:var(--surface)] p-5">
            <summary class="cursor-pointer font-semibold">{it.q}</summary>
            <p class="mt-2 text-sm text-[color:var(--muted)]">{it.a}</p>
          </details>
        ))}
      </div>
    </div>
  </main>

  <CTA
    locale={locale}
    ctx={{ kind: 'generic' }}
    title={'¿Listo para lanzar tu sitio en <em>días</em>?'}
    subtitle={'Escríbeme por WhatsApp y empezamos con el brief.'}
  />
  <Footer locale={locale} />
</BaseLayout>
