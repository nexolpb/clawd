---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import PricingCards from '../../components/PricingCards.astro';
import Testimonials from '../../components/Testimonials.astro';
import StickyWhatsApp from '../../components/StickyWhatsApp.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import HomeExamplesPreview from '../../components/HomeExamplesPreview.astro';
import FAQ from '../../components/FAQ.astro';
import FreePreview from '../../components/FreePreview.astro';
import { t } from '../../i18n';
import { SITE } from '../../config/site';
import { whatsappLink } from '../../utils/whatsapp';

const locale = 'es' as const;
const tr = t(locale);
const whatsappHref = whatsappLink(locale, { kind: 'generic' });
---
<BaseLayout locale={locale} title={tr.meta.homeTitle} description={tr.meta.homeDesc} canonicalPath="/es/" >
  <Header locale={locale} active="home" />

  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 opacity-30 bg-grid"></div>
      <div class="mx-auto max-w-6xl px-4 py-14 md:py-20">
        <div class="grid items-center gap-10 md:grid-cols-2">
          <div class="prose-em">
            <div class="inline-flex items-center gap-2 rounded-full border border-[color:var(--border)] bg-[color:var(--surface)] px-3 py-1 text-xs text-[color:var(--muted)]">
              <span class="h-2 w-2 rounded-full bg-[color:var(--primary)]"></span>
              <span>{tr.badges.product}</span>
            </div>
            <h1 class="mt-4 text-balance text-4xl font-extrabold md:text-5xl" set:html={tr.hero.title} />
            <p class="mt-4 text-[color:var(--muted)]">{tr.hero.subtitle}</p>

            <ul class="mt-5 grid gap-2 text-sm text-[color:var(--muted)]">
              <li class="flex gap-2"><span class="text-[color:var(--success)]">✓</span><span>WhatsApp y llamadas con un solo clic</span></li>
              <li class="flex gap-2"><span class="text-[color:var(--success)]">✓</span><span>Conectado con tu ubicación en Google Maps</span></li>
              <li class="flex gap-2"><span class="text-[color:var(--success)]">✓</span><span>Tu sitio web listo en 5–14 días hábiles</span></li>
            </ul>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <a class="inline-flex items-center justify-center rounded-md bg-[color:var(--primary)] px-5 py-3 text-sm font-semibold text-[color:var(--bg)] transition hover:bg-[color:var(--accent)]" href={whatsappHref} target="_blank" rel="noopener">{tr.cta.whatsapp}</a>
              <a class="inline-flex items-center justify-center rounded-md border border-[color:var(--border)] bg-[color:var(--surface)] px-5 py-3 text-sm font-semibold text-[color:var(--text)] transition hover:border-[color:var(--primary)]" href="/es/pricing/">{tr.cta.seePricing}</a>
            </div>

            <div class="mt-4 text-xs text-[color:var(--muted)]">
              {SITE.minResponseTime[locale]}{tr.hero.proof ? ` · ${tr.hero.proof}` : ''}
            </div>
          </div>

          <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
            <div class="flex items-center justify-between">
              <div class="text-sm font-semibold">Preview</div>
              <div class="rounded-full bg-[color:var(--surface2)] px-3 py-1 text-xs text-[color:var(--muted)]">WhatsApp-first</div>
            </div>
            <div class="mt-4 rounded-xl border border-[color:var(--border)] bg-[color:var(--bg)] p-4">
              <div class="h-28 rounded-lg bg-[color:var(--surface2)] overflow-hidden">
  <svg viewBox="0 0 640 220" class="h-full w-full" role="img" aria-label="Mockup de conversación por WhatsApp">
    <defs>
      <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="rgba(37,211,102,0.25)"/>
        <stop offset="1" stop-color="rgba(37,211,102,0.05)"/>
      </linearGradient>
      <filter id="s" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="6" stdDeviation="8" flood-color="rgba(0,0,0,0.35)"/>
      </filter>
    </defs>

    <rect x="0" y="0" width="640" height="220" fill="url(#g)" opacity="0.9"/>

    <!-- phone -->
    <g filter="url(#s)">
      <rect x="360" y="18" rx="24" ry="24" width="240" height="184" fill="rgba(12,12,12,0.55)" stroke="rgba(240,239,232,0.18)"/>
      <rect x="380" y="40" rx="16" ry="16" width="200" height="140" fill="rgba(240,239,232,0.06)" stroke="rgba(240,239,232,0.12)"/>
      <circle cx="480" cy="193" r="10" fill="rgba(240,239,232,0.10)" stroke="rgba(240,239,232,0.15)"/>
    </g>

    <!-- chat bubbles -->
    <g>
      <rect x="395" y="56" rx="12" ry="12" width="150" height="28" fill="rgba(240,239,232,0.08)"/>
      <rect x="420" y="92" rx="12" ry="12" width="150" height="28" fill="rgba(37,211,102,0.22)"/>
      <rect x="395" y="128" rx="12" ry="12" width="132" height="28" fill="rgba(240,239,232,0.08)"/>
      <rect x="405" y="60" rx="3" ry="3" width="88" height="4" fill="rgba(240,239,232,0.30)"/>
      <rect x="405" y="70" rx="3" ry="3" width="60" height="4" fill="rgba(240,239,232,0.22)"/>
      <rect x="430" y="96" rx="3" ry="3" width="96" height="4" fill="rgba(240,239,232,0.42)"/>
      <rect x="430" y="106" rx="3" ry="3" width="70" height="4" fill="rgba(240,239,232,0.26)"/>
      <rect x="405" y="132" rx="3" ry="3" width="78" height="4" fill="rgba(240,239,232,0.30)"/>
      <rect x="405" y="142" rx="3" ry="3" width="54" height="4" fill="rgba(240,239,232,0.22)"/>
    </g>

    <!-- left label / hint -->
    <g>
      <text x="28" y="88" font-family="ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial" font-size="18" fill="rgba(240,239,232,0.80)">WhatsApp-first</text>
      <text x="28" y="114" font-family="ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial" font-size="12" fill="rgba(240,239,232,0.60)">CTA visible · mensaje prellenado · respuesta rápida</text>
      <circle cx="28" cy="60" r="10" fill="rgba(37,211,102,0.55)"/>
      <path d="M24 60c0-5 8-5 8 0 0 4-4 7-4 7s-4-3-4-7z" fill="rgba(12,12,12,0.55)"/>
    </g>
  </svg>
</div>
              <div class="mt-3 grid grid-cols-2 gap-2">
                <div class="rounded-lg bg-[color:var(--surface2)] p-3 text-center">
                  <div class="tabular text-lg font-bold text-[color:var(--primary)]">4.8★</div>
                  <div class="text-xs text-[color:var(--muted)]">Google</div>
                </div>
                <div class="rounded-lg bg-[color:var(--surface2)] p-3 text-center">
                  <div class="tabular text-lg font-bold text-[color:var(--primary)]">+30%</div>
                  <div class="text-xs text-[color:var(--muted)]">Leads</div>
                </div>
              </div>
              <a class="mt-3 inline-flex w-full items-center justify-center rounded-md bg-[#25D366] px-4 py-2 text-sm font-semibold text-white" href={whatsappHref} target="_blank" rel="noopener">WhatsApp</a>
            </div>
          </div>
        </div>

        <TrustStrip locale={locale} />

        <!-- Stats -->
        <div class="mt-4 grid overflow-hidden rounded-xl border border-[color:var(--border)] bg-[color:var(--surface)] md:grid-cols-4">
          <div class="p-6 text-center border-b border-[color:var(--border)] md:border-b-0 md:border-r">
            <div class="tabular text-3xl font-extrabold text-[color:var(--primary)]">40+</div>
            <div class="mt-1 text-xs text-[color:var(--muted)]">{tr.hero.stats.clients}</div>
          </div>
          <div class="p-6 text-center border-b border-[color:var(--border)] md:border-b-0 md:border-r">
            <div class="tabular text-3xl font-extrabold text-[color:var(--primary)]">5–14</div>
            <div class="mt-1 text-xs text-[color:var(--muted)]">{tr.hero.stats.speed}</div>
          </div>
          <div class="p-6 text-center border-b border-[color:var(--border)] md:border-b-0 md:border-r">
            <div class="tabular text-3xl font-extrabold text-[color:var(--primary)]">90+</div>
            <div class="mt-1 text-xs text-[color:var(--muted)]">{tr.hero.stats.lighthouse}</div>
          </div>
          <div class="p-6 text-center">
            <div class="tabular text-3xl font-extrabold text-[color:var(--primary)]">100%</div>
            <div class="mt-1 text-xs text-[color:var(--muted)]">{tr.hero.stats.mobile}</div>
          </div>
        </div>

        <p class="mt-4 text-sm text-[color:var(--muted)]">
          Hecho para negocios de servicios que dependen de llamadas, mensajes y búsquedas locales en Google.
        </p>
      </div>
    </section>

    <!-- DOLOR -->
    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-10 md:grid-cols-2">
        <div>
          <div class="text-xs uppercase tracking-widest text-[color:var(--muted)]">Por qué pasa</div>
          <h2 class="mt-2 text-3xl font-extrabold">Por qué fallan la mayoría de los sitios de negocios pequeños</h2>
          <p class="mt-3 text-[color:var(--muted)]">Muchos sitios se ven bonitos, pero no generan clientes.</p>
        </div>
        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
          <ul class="grid gap-2 text-sm text-[color:var(--muted)]">
            <li class="flex gap-2"><span class="text-[color:var(--success)]">✕</span><span>Es difícil contactar al negocio</span></li>
            <li class="flex gap-2"><span class="text-[color:var(--success)]">✕</span><span>No hay un CTA claro</span></li>
            <li class="flex gap-2"><span class="text-[color:var(--success)]">✕</span><span>No está optimizado para móvil</span></li>
            <li class="flex gap-2"><span class="text-[color:var(--success)]">✕</span><span>Carga lento</span></li>
            <li class="flex gap-2"><span class="text-[color:var(--success)]">✕</span><span>No está conectado a Google Maps</span></li>
            <li class="flex gap-2"><span class="text-[color:var(--success)]">✕</span><span>No tiene estructura para Google Ads</span></li>
          </ul>
          <div class="mt-4 rounded-xl bg-[color:var(--surface2)] px-4 py-3 text-sm text-[color:var(--muted)]">
            Resultado: las visitas se van sin llamar ni escribir.
          </div>
        </div>
      </div>
    </section>

    <!-- VALUE -->
    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-2xl">
        <div class="text-xs uppercase tracking-widest text-[color:var(--muted)]">{tr.badges.why}</div>
        <h2 class="mt-2 text-3xl font-extrabold">{tr.value.title}</h2>
        <p class="mt-3 text-[color:var(--muted)]">{tr.value.subtitle}</p>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {tr.value.cards.map((c) => (
          <div class="rounded-xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
            <div class="text-lg font-bold">{c.title}</div>
            <p class="mt-2 text-sm text-[color:var(--muted)]">{c.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- BENEFICIOS -->
    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-2xl">
        <div class="text-xs uppercase tracking-widest text-[color:var(--muted)]">Resultados</div>
        <h2 class="mt-2 text-3xl font-extrabold">Lo que tu sitio realmente hará por tu negocio</h2>
        <p class="mt-3 text-[color:var(--muted)]">Beneficios en lenguaje simple.</p>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
          <div class="flex items-center gap-3">
            <div class="grid h-10 w-10 place-items-center rounded-xl bg-[color:var(--surface2)] text-[color:var(--primary)]">
              <span aria-hidden="true">✉︎</span>
            </div>
            <div class="text-lg font-bold">Más mensajes</div>
          </div>
          <p class="mt-2 text-sm text-[color:var(--muted)]">Un botón de WhatsApp visible hace fácil que te escriban al instante.</p>
        </div>

        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
          <div class="flex items-center gap-3">
            <div class="grid h-10 w-10 place-items-center rounded-xl bg-[color:var(--surface2)] text-[color:var(--primary)]">
              <span aria-hidden="true">☎︎</span>
            </div>
            <div class="text-lg font-bold">Más llamadas</div>
          </div>
          <p class="mt-2 text-sm text-[color:var(--muted)]">Botones de llamada con 1 tap para que te llamen desde el celular.</p>
        </div>

        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
          <div class="flex items-center gap-3">
            <div class="grid h-10 w-10 place-items-center rounded-xl bg-[color:var(--surface2)] text-[color:var(--primary)]">
              <span aria-hidden="true">★</span>
            </div>
            <div class="text-lg font-bold">Más confianza</div>
          </div>
          <p class="mt-2 text-sm text-[color:var(--muted)]">Estructura clara + conexión a Google Maps aumentan credibilidad.</p>
        </div>

        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
          <div class="flex items-center gap-3">
            <div class="grid h-10 w-10 place-items-center rounded-xl bg-[color:var(--surface2)] text-[color:var(--primary)]">
              <span aria-hidden="true">⚡︎</span>
            </div>
            <div class="text-lg font-bold">Listo para marketing</div>
          </div>
          <p class="mt-2 text-sm text-[color:var(--muted)]">Si luego quieres hacer Google Ads, el sitio ya está estructurado para eso.</p>
        </div>
      </div>
    </section>

    <CTA
      locale={locale}
      ctx={{ kind: 'generic' }}
      title={'¿Quieres un sitio que te traiga <em>mensajes</em> y <em>llamadas</em>?'}
      subtitle={'Escríbeme por WhatsApp y te recomiendo el mejor plan para tu negocio.'}
    />

    <!-- NICHES -->
    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-8 md:grid-cols-2">
        <div>
          <h2 class="text-3xl font-extrabold">{tr.niches.title}</h2>
          <p class="mt-3 text-[color:var(--muted)]">{tr.niches.subtitle}</p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {tr.niches.items.map((i) => (
            <div class="rounded-lg border border-[color:var(--border)] bg-[color:var(--surface)] px-4 py-3 text-sm text-[color:var(--text)]">{i}</div>
          ))}
        </div>
      </div>
    </section>

    <HomeExamplesPreview locale={locale} />

    <!-- PROCESS -->
    <section class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-3xl font-extrabold">{tr.process.title}</h2>
      <p class="mt-3 max-w-2xl text-[color:var(--muted)]">{tr.process.subtitle}</p>
      <div class="mt-8 grid gap-6 md:grid-cols-5">
        {tr.process.steps.map((s, idx) => (
          <div class="rounded-xl border border-[color:var(--border)] bg-[color:var(--surface)] p-5">
            <div class="tabular text-xs font-semibold text-[color:var(--accent)]">0{idx+1}</div>
            <div class="mt-2 font-bold">{s.title}</div>
            <div class="mt-2 text-sm text-[color:var(--muted)]">{s.desc}</div>
          </div>
        ))}
      </div>
      <div class="mt-8 flex gap-3">
        <a class="inline-flex items-center justify-center rounded-md bg-[color:var(--primary)] px-5 py-3 text-sm font-semibold text-[color:var(--bg)] transition hover:bg-[color:var(--accent)]" href="/es/process/">Ver detalles</a>
        <a class="inline-flex items-center justify-center rounded-md border border-[color:var(--border)] bg-[color:var(--surface)] px-5 py-3 text-sm font-semibold text-[color:var(--text)] transition hover:border-[color:var(--primary)]" href="/es/contact/">{tr.cta.getQuote}</a>
      </div>
    </section>

    <Testimonials locale={locale} />

    <FreePreview locale={locale} />

    <!-- PRICING -->
    <section class="mx-auto max-w-6xl px-4 py-14" id="pricing">
      <h2 class="text-3xl font-extrabold">{tr.pricing.title}</h2>
      <p class="mt-3 max-w-2xl text-[color:var(--muted)]">{tr.pricing.subtitle}</p>
      <div class="mt-8">
        <PricingCards locale={locale} />
      </div>

      <div class="mt-6 rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
        <div class="text-sm font-semibold">Todos los planes incluyen</div>
        <ul class="mt-3 grid gap-2 text-sm text-[color:var(--muted)]">
          <li class="flex gap-2"><span class="text-[color:var(--success)]">✓</span><span>Diseño</span></li>
          <li class="flex gap-2"><span class="text-[color:var(--success)]">✓</span><span>Publicación</span></li>
          <li class="flex gap-2"><span class="text-[color:var(--success)]">✓</span><span>Configuración de dominio</span></li>
          <li class="flex gap-2"><span class="text-[color:var(--success)]">✓</span><span>Guía para configurar hosting</span></li>
        </ul>
      </div>
    </section>

    <CTA
      locale={locale}
      ctx={{ kind: 'generic' }}
      title={'¿Quieres lanzar en <em>5–14 días</em>?'}
      subtitle={'Escríbeme por WhatsApp y te confirmo el mejor plan y el timeline para tu negocio.'}
    />

    <FAQ locale={locale} />

    <CTA
      locale={locale}
      ctx={{ kind: 'generic' }}
      title={'¿Listo para un sitio que te traiga <em>clientes</em>?'}
      subtitle={'Escríbeme por WhatsApp y te recomiendo el mejor plan para tu negocio.'}
    />
  </main>

  <StickyWhatsApp locale={locale} />
  <Footer locale={locale} />
</BaseLayout>
