---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import { t } from '../../i18n';
import { SITE } from '../../config/site';
import { whatsappLink } from '../../utils/whatsapp';

const locale = 'es' as const;
const tr = t(locale);
const whatsappHref = whatsappLink(locale, { kind: 'contact' });
---
<BaseLayout locale={locale} title={tr.meta.contactTitle} description={tr.meta.contactDesc} canonicalPath="/es/contact/" >
  <Header locale={locale} active="contact" />

  <main class="mx-auto max-w-6xl px-4 py-14">
    <div class="grid gap-10 md:grid-cols-2">
      <div>
        <h1 class="text-4xl font-extrabold">{tr.contact.title}</h1>
        <p class="mt-3 text-[color:var(--muted)]">{tr.contact.subtitle}</p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a class="inline-flex items-center justify-center rounded-md bg-[color:var(--primary)] px-5 py-3 text-sm font-semibold text-[color:var(--bg)] transition hover:bg-[color:var(--accent)]" href={whatsappHref} target="_blank" rel="noopener">{tr.cta.whatsapp}</a>
          <a class="inline-flex items-center justify-center rounded-md border border-[color:var(--border)] bg-[color:var(--surface)] px-5 py-3 text-sm font-semibold text-[color:var(--text)] transition hover:border-[color:var(--primary)]" href={SITE.calendlyUrl} target="_blank" rel="noopener">{tr.cta.bookCall}</a>
        </div>

        <div class="mt-4 text-sm text-[color:var(--muted)]">Email: <a class="text-[color:var(--text)] underline" href={`mailto:${SITE.email}`}>{SITE.email}</a></div>
        <div class="mt-2 text-xs text-[color:var(--muted)]">{SITE.minResponseTime[locale]}</div>
      </div>

      <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-6">
        <h2 class="text-2xl font-extrabold">{tr.contact.formTitle}</h2>
        <form class="mt-6 grid gap-3" name="nexo-sites-intake" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="nexo-sites-intake" />

          <label class="grid gap-1">
            <span class="text-sm text-[color:var(--muted)]">{tr.contact.fields.name}</span>
            <input class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="name" required />
          </label>

          <label class="grid gap-1">
            <span class="text-sm text-[color:var(--muted)]">{tr.contact.fields.business}</span>
            <input class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="business" required />
          </label>

          <div class="grid gap-3 md:grid-cols-2">
            <label class="grid gap-1">
              <span class="text-sm text-[color:var(--muted)]">{tr.contact.fields.location}</span>
              <input class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="location" required />
            </label>
            <label class="grid gap-1">
              <span class="text-sm text-[color:var(--muted)]">{tr.contact.fields.niche}</span>
              <select class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="niche" required>
                <option value="">Selecciona…</option>
                <option>Veterinaria</option>
                <option>Clínica dental</option>
                <option>Abogado / bufete</option>
                <option>Salud (médico / clínica)</option>
                <option>Servicios del hogar</option>
                <option>Belleza (salón / spa)</option>
                <option>Restaurante</option>
                <option>Gimnasio</option>
                <option>Bienes raíces</option>
                <option>Otro</option>
              </select>
            </label>
          </div>

          <div class="grid gap-3 md:grid-cols-2">
            <label class="grid gap-1">
              <span class="text-sm text-[color:var(--muted)]">Presupuesto (opcional)</span>
              <select class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="budget">
                <option value="">Selecciona…</option>
                <option>$300–$500</option>
                <option>$500–$800</option>
                <option>$800–$1,200</option>
                <option>$1,200+</option>
              </select>
            </label>
            <label class="grid gap-1">
              <span class="text-sm text-[color:var(--muted)]">¿Ya tienes dominio?</span>
              <select class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="has_domain">
                <option value="">Selecciona…</option>
                <option>Sí</option>
                <option>No</option>
                <option>No estoy seguro</option>
              </select>
            </label>
          </div>

          <label class="grid gap-1">
            <span class="text-sm text-[color:var(--muted)]">{tr.contact.fields.site}</span>
            <input class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="current_site" placeholder="https://" />
          </label>

          <label class="grid gap-1">
            <span class="text-sm text-[color:var(--muted)]">{tr.contact.fields.gbp}</span>
            <input class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="gbp" placeholder="https://maps.google.com/..." />
          </label>

          <label class="grid gap-1">
            <span class="text-sm text-[color:var(--muted)]">{tr.contact.fields.contact}</span>
            <input class="rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="contact" required />
          </label>

          <label class="grid gap-1">
            <span class="text-sm text-[color:var(--muted)]">{tr.contact.fields.message}</span>
            <textarea class="min-h-28 rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-2" name="message" required></textarea>
          </label>

          <button class="mt-2 inline-flex items-center justify-center rounded-md bg-[color:var(--primary)] px-5 py-3 text-sm font-semibold text-[color:var(--bg)] transition hover:bg-[color:var(--accent)]" type="submit">{tr.contact.submit}</button>
          <div class="text-xs text-[color:var(--muted)]">{tr.contact.privacy}</div>
        </form>
      </div>
    </div>
  </main>

  <CTA
    locale={locale}
    ctx={{ kind: 'contact' }}
    title={'¿Listo para lanzar?'}
    subtitle={'Si prefieres, escríbeme por WhatsApp y te guío con el brief.'}
  />
  <Footer locale={locale} />
</BaseLayout>
