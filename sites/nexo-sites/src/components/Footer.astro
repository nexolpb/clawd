---
import { SITE } from '../config/site';
import type { Locale } from '../i18n/locales';
import { t } from '../i18n';

const { locale } = Astro.props as { locale: Locale };
const tr = t(locale);
const year = new Date().getFullYear();
---
<footer class="border-t border-[color:var(--border)] bg-[color:var(--bg)]">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="font-[family:var(--font-display)] text-xl font-extrabold">Nexo Sites</div>
        <p class="mt-2 text-sm text-[color:var(--muted)]">{tr.footer.tagline}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a class="rounded-md border border-[color:var(--border)] bg-[color:var(--surface)] px-3 py-2 text-sm hover:border-[color:var(--primary)]" href={SITE.parentUrl} target="_blank" rel="noopener">nexodigitalops.com</a>
          <a class="rounded-md border border-[color:var(--border)] bg-[color:var(--surface)] px-3 py-2 text-sm hover:border-[color:var(--primary)]" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          <a class="rounded-md border border-[color:var(--border)] bg-[color:var(--surface)] px-3 py-2 text-sm hover:border-[color:var(--primary)]" href={SITE.calendlyUrl} target="_blank" rel="noopener">Calendly</a>
        </div>
      </div>

      <div>
        <div class="text-sm font-semibold">{locale === 'es' ? 'Navegación' : 'Navigation'}</div>
        <ul class="mt-3 space-y-2 text-sm text-[color:var(--muted)]">
          <li><a class="hover:text-[color:var(--text)]" href={`/${locale}/`}>{tr.nav.home}</a></li>
          <li><a class="hover:text-[color:var(--text)]" href={`/${locale}/pricing/`}>{tr.nav.pricing}</a></li>
          <li><a class="hover:text-[color:var(--text)]" href={`/${locale}/examples/`}>{tr.nav.examples}</a></li>
          <li><a class="hover:text-[color:var(--text)]" href={`/${locale}/process/`}>{tr.nav.process}</a></li>
          <li><a class="hover:text-[color:var(--text)]" href={`/${locale}/contact/`}>{tr.nav.contact}</a></li>
        </ul>
      </div>

      <div>
        <div class="text-sm font-semibold">{locale === 'es' ? 'Contacto' : 'Contact'}</div>
        <ul class="mt-3 space-y-2 text-sm text-[color:var(--muted)]">
          <li><a class="hover:text-[color:var(--text)]" href={SITE.whatsapp.waMe} target="_blank" rel="noopener">WhatsApp {SITE.whatsapp.phoneE164}</a></li>
          <li><a class="hover:text-[color:var(--text)]" href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-[color:var(--border)] pt-6 text-xs text-[color:var(--muted)] md:flex-row md:items-center md:justify-between">
      <span>© {year} Nexo Sites · {tr.footer.rights}</span>
      <span>{tr.footer.privacy}</span>
    </div>
  </div>
</footer>
