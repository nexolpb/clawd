---
import type { Locale } from '../i18n/locales';

const { locale } = Astro.props as { locale: Locale };
const items = locale === 'es'
  ? [
      { k: 'Listo para móvil', v: 'Diseño mobile-first' },
      { k: 'WhatsApp-first', v: 'CTA siempre visible' },
      { k: 'GBP', v: 'Conectado a Google Maps' },
      { k: 'Ads-ready', v: 'Base para Google Ads' }
    ]
  : [
      { k: 'Mobile', v: 'Mobile-first design' },
      { k: 'WhatsApp-first', v: 'Always-visible CTA' },
      { k: 'GBP', v: 'Connected to Google Maps' },
      { k: 'Ads-ready', v: 'Foundation for Google Ads' }
    ];
---
<section class="mx-auto max-w-6xl px-4 pb-8">
  <div class="grid gap-3 rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-4 md:grid-cols-4">
    {items.map((i) => (
      <div class="flex items-center justify-between rounded-xl bg-[color:var(--surface2)] px-4 py-3">
        <div class="text-xs font-semibold text-[color:var(--accent)]">{i.k}</div>
        <div class="text-xs text-[color:var(--muted)]">{i.v}</div>
      </div>
    ))}
  </div>
</section>
