---
import { SITE } from '../config/site';
import type { Locale } from '../i18n/locales';
import { t } from '../i18n';
import { whatsappLink, type WhatsAppContext } from '../utils/whatsapp';

const { locale, title, subtitle, ctx } = Astro.props as { locale: Locale; title: string; subtitle: string; ctx?: WhatsAppContext };
const tr = t(locale);
const href = whatsappLink(locale, ctx ?? { kind: 'generic' });
const callHref = SITE.calendlyUrl.includes('your-link') ? `/${locale}/contact/` : SITE.calendlyUrl;
const callTarget = SITE.calendlyUrl.includes('your-link') ? undefined : '_blank';
---
<section class="relative overflow-hidden border-y border-[color:var(--border)] bg-[color:var(--surface)]">
  <div class="absolute inset-0 opacity-40 bg-grid"></div>
  <div class="relative mx-auto max-w-6xl px-4 py-12">
    <div class="grid items-center gap-8 md:grid-cols-2">
      <div class="prose-em">
        <h2 class="text-balance text-2xl font-extrabold md:text-3xl" set:html={title} />
        <p class="mt-3 text-sm text-[color:var(--muted)]">{subtitle}</p>
      </div>
      <div class="flex flex-col gap-3 md:items-end">
        <a class="inline-flex items-center justify-center rounded-md bg-[color:var(--primary)] px-4 py-3 text-sm font-semibold text-[color:var(--bg)] transition hover:bg-[color:var(--accent)]" href={href} target="_blank" rel="noopener">{tr.cta.whatsapp}</a>
        <a class="inline-flex items-center justify-center rounded-md border border-[color:var(--border)] bg-[color:var(--bg)] px-4 py-3 text-sm font-semibold text-[color:var(--text)] transition hover:border-[color:var(--primary)]" href={callHref} target={callTarget} rel={callTarget ? 'noopener' : undefined}>{tr.cta.bookCall}</a>
        <div class="text-xs text-[color:var(--muted)]">{SITE.minResponseTime[locale]}</div>
      </div>
    </div>
  </div>
</section>
