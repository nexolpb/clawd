---
import type { Locale } from '../i18n/locales';
import { whatsappLink } from '../utils/whatsapp';

type Props = {
  locale: Locale;
  active: 'home' | 'pricing' | 'examples' | 'process' | 'contact';
};

const { locale, active } = Astro.props;
const other = locale === 'es' ? 'en' : 'es';
const nav = {
  es: {
    home: 'Inicio', pricing: 'Precios', examples: 'Ejemplos', process: 'Proceso', contact: 'Contacto', lang: 'EN',
  },
  en: {
    home: 'Home', pricing: 'Pricing', examples: 'Examples', process: 'Process', contact: 'Contact', lang: 'ES',
  }
}[locale];

const whatsappHref =
  active === 'pricing'
    ? whatsappLink(locale, { kind: 'pricing' })
    : active === 'examples'
      ? whatsappLink(locale, { kind: 'examples', niche: locale === 'es' ? 'mi industria' : 'my industry' })
      : active === 'contact'
        ? whatsappLink(locale, { kind: 'contact' })
        : whatsappLink(locale, { kind: 'generic' });
---
<header class="sticky top-0 z-50 border-b border-[color:var(--border)] bg-[color:var(--bg)]/85 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href={`/${locale}/`} class="flex items-center gap-2">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[color:var(--border)] bg-[color:var(--surface2)]">
        <span class="font-[family:var(--font-display)] font-extrabold text-[color:var(--primary)]">N</span>
      </span>
      <span class="leading-tight">
        <span class="block font-[family:var(--font-display)] font-extrabold tracking-tight">Nexo Sites</span>
        <span class="block text-xs text-[color:var(--muted)]">by Nexo Digital Ops</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      <a class={"text-sm transition hover:text-[color:var(--accent)] " + (active==='home' ? 'text-[color:var(--accent)]' : 'text-[color:var(--text)]')} href={`/${locale}/`}>{nav.home}</a>
      <a class={"text-sm transition hover:text-[color:var(--accent)] " + (active==='pricing' ? 'text-[color:var(--accent)]' : 'text-[color:var(--text)]')} href={`/${locale}/pricing/`}>{nav.pricing}</a>
      <a class={"text-sm transition hover:text-[color:var(--accent)] " + (active==='examples' ? 'text-[color:var(--accent)]' : 'text-[color:var(--text)]')} href={`/${locale}/examples/`}>{nav.examples}</a>
      <a class={"text-sm transition hover:text-[color:var(--accent)] " + (active==='process' ? 'text-[color:var(--accent)]' : 'text-[color:var(--text)]')} href={`/${locale}/process/`}>{nav.process}</a>
      <a class={"text-sm transition hover:text-[color:var(--accent)] " + (active==='contact' ? 'text-[color:var(--accent)]' : 'text-[color:var(--text)]')} href={`/${locale}/contact/`}>{nav.contact}</a>
    </nav>

    <div class="flex items-center gap-2">
      <!-- Language toggle pill -->
      <div class="hidden md:flex items-center rounded-full border border-[color:var(--border)] bg-[color:var(--surface)] p-1">
        <a
          href={`/es/${active === 'home' ? '' : active + '/'}`}
          class={"rounded-full px-3 py-1 text-xs font-semibold transition " + (locale==='es' ? 'bg-[color:var(--accent)] text-[color:var(--bg)]' : 'text-[color:var(--muted)] hover:text-[color:var(--text)]')}
          data-locale-switch
        >
          ES
        </a>
        <a
          href={`/en/${active === 'home' ? '' : active + '/'}`}
          class={"rounded-full px-3 py-1 text-xs font-semibold transition " + (locale==='en' ? 'bg-[color:var(--accent)] text-[color:var(--bg)]' : 'text-[color:var(--muted)] hover:text-[color:var(--text)]')}
          data-locale-switch
        >
          EN
        </a>
      </div>
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center rounded-full bg-[color:var(--primary)] px-4 py-2 text-sm font-semibold text-[color:var(--bg)] transition hover:bg-[color:var(--accent)]"
      >
        WhatsApp
      </a>
    </div>

    <button class="md:hidden rounded-md border border-[color:var(--border)] bg-[color:var(--surface)] px-3 py-2 text-sm" id="menuBtn">Menu</button>
  </div>

  <div class="md:hidden hidden border-t border-[color:var(--border)] bg-[color:var(--bg)]" id="mobileMenu">
    <div class="mx-auto max-w-6xl px-4 py-3 flex flex-col gap-3">
      <a class="text-sm" href={`/${locale}/`}>{nav.home}</a>
      <a class="text-sm" href={`/${locale}/pricing/`}>{nav.pricing}</a>
      <a class="text-sm" href={`/${locale}/examples/`}>{nav.examples}</a>
      <a class="text-sm" href={`/${locale}/process/`}>{nav.process}</a>
      <a class="text-sm" href={`/${locale}/contact/`}>{nav.contact}</a>
      <a class="text-sm text-[color:var(--accent)]" href={`/${other}/${active === 'home' ? '' : active + '/'}`} data-locale-switch>{nav.lang}</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menuBtn');
  const menu = document.getElementById('mobileMenu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  // persist locale
  document.querySelectorAll('[data-locale-switch]').forEach((a) => {
    a.addEventListener('click', () => {
      try { localStorage.setItem('nexo_sites_locale', document.documentElement.lang); } catch(e) {}
    });
  });
</script>
